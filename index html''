 <!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuizMaster — Testez vos connaissances</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --border: rgba(255,255,255,0.07);
    --accent: #7c3aed;
    --accent2: #06b6d4;
    --accent3: #f59e0b;
    --text: #f0f0f8;
    --text-muted: #6b7280;
    --correct: #10b981;
    --wrong: #ef4444;
    --radius: 16px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .bg-canvas {
    position: fixed; inset: 0; z-index: 0; overflow: hidden;
  }
  .orb {
    position: absolute; border-radius: 50%; filter: blur(80px);
    opacity: 0.15; animation: float 8s ease-in-out infinite;
  }
  .orb-1 { width:500px; height:500px; background:var(--accent); top:-10%; left:-10%; animation-delay:0s; }
  .orb-2 { width:400px; height:400px; background:var(--accent2); bottom:-5%; right:-5%; animation-delay:-3s; }
  .orb-3 { width:300px; height:300px; background:var(--accent3); top:40%; left:60%; animation-delay:-6s; }
  @keyframes float {
    0%,100% { transform:translate(0,0) scale(1); }
    33%  { transform:translate(30px,-30px) scale(1.05); }
    66%  { transform:translate(-20px,20px) scale(0.95); }
  }
  .bg-canvas::after {
    content:''; position:absolute; inset:0;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity:0.4; pointer-events:none;
  }

  .app {
    position:relative; z-index:1; min-height:100vh;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center; padding:24px;
  }

  .screen { display:none; width:100%; max-width:720px; animation:slideIn 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  .screen.active { display:block; }
  @keyframes slideIn {
    from { opacity:0; transform:translateY(30px) scale(0.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }

  .card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:24px; padding:48px; backdrop-filter:blur(20px);
    box-shadow:0 32px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  /* ── HOME ── */
  .home-badge {
    display:inline-flex; align-items:center; gap:8px;
    background:rgba(124,58,237,0.15); border:1px solid rgba(124,58,237,0.3);
    border-radius:100px; padding:6px 16px; font-size:13px; font-weight:500;
    color:#a78bfa; margin-bottom:32px; letter-spacing:0.05em; text-transform:uppercase;
  }
  .home-badge::before { content:'✦'; }

  h1 {
    font-family:'Syne',sans-serif; font-size:clamp(48px,8vw,80px);
    font-weight:800; line-height:0.95; letter-spacing:-0.03em; margin-bottom:20px;
  }
  h1 span {
    background:linear-gradient(135deg,#7c3aed,#06b6d4,#f59e0b);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  }

  .home-desc { color:var(--text-muted); font-size:18px; line-height:1.6; max-width:480px; margin-bottom:48px; }

  .cat-label { font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--text-muted); margin-bottom:16px; }
  .category-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:32px; }
  .cat-btn {
    background:var(--surface2); border:1px solid var(--border); border-radius:14px;
    padding:20px 16px; cursor:pointer; transition:all 0.2s; text-align:center;
    color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500;
  }
  .cat-btn .cat-emoji { font-size:28px; display:block; margin-bottom:8px; }
  .cat-btn:hover { border-color:var(--accent); background:rgba(124,58,237,0.1); transform:translateY(-2px); }
  .cat-btn.selected { border-color:var(--accent); background:rgba(124,58,237,0.2); box-shadow:0 0 20px rgba(124,58,237,0.3); }

  .diff-row { display:flex; gap:10px; margin-bottom:40px; }
  .diff-btn {
    flex:1; padding:12px; border-radius:10px; border:1px solid var(--border);
    background:var(--surface2); color:var(--text-muted); cursor:pointer;
    font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500;
    transition:all 0.2s; text-align:center;
  }
  .diff-btn:hover { border-color:rgba(255,255,255,0.2); color:var(--text); }
  .diff-btn[data-diff="facile"].selected  { border-color:var(--correct);  background:rgba(16,185,129,0.15); color:var(--correct); }
  .diff-btn[data-diff="moyen"].selected   { border-color:var(--accent3);  background:rgba(245,158,11,0.15); color:var(--accent3); }
  .diff-btn[data-diff="difficile"].selected { border-color:var(--wrong);  background:rgba(239,68,68,0.15);  color:var(--wrong); }

  /* ── BUTTONS ── */
  .btn-primary {
    display:inline-flex; align-items:center; justify-content:center; gap:10px;
    background:linear-gradient(135deg,#7c3aed,#5b21b6); color:white; border:none;
    border-radius:14px; padding:18px 36px; font-family:'Syne',sans-serif;
    font-size:16px; font-weight:700; letter-spacing:0.02em; cursor:pointer;
    transition:all 0.2s; box-shadow:0 8px 32px rgba(124,58,237,0.4); width:100%;
  }
  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 12px 40px rgba(124,58,237,0.5); }
  .btn-primary:active { transform:translateY(0); }
  .btn-primary:disabled { opacity:0.4; cursor:not-allowed; transform:none; }

  .btn-secondary {
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    background:transparent; color:var(--text-muted); border:1px solid var(--border);
    border-radius:14px; padding:14px 24px; font-family:'DM Sans',sans-serif;
    font-size:15px; font-weight:500; cursor:pointer; transition:all 0.2s;
  }
  .btn-secondary:hover { border-color:rgba(255,255,255,0.2); color:var(--text); }

  /* ── QUIZ HEADER ── */
  .quiz-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:32px; }
  .quiz-meta { display:flex; align-items:center; gap:16px; }
  .quiz-cat-tag {
    background:rgba(124,58,237,0.2); border:1px solid rgba(124,58,237,0.3);
    color:#a78bfa; border-radius:8px; padding:4px 12px; font-size:12px;
    font-weight:600; letter-spacing:0.05em; text-transform:uppercase;
  }
  .q-counter { font-size:14px; color:var(--text-muted); font-weight:500; }

  /* ─────────────────────────────────────────────────────────────────────
     ÉTAPE 3 — INSTRUCTION 1 & 4 : Affichage du score en temps réel
     Un compteur de score visible en permanence dans l'en-tête du quiz
     ───────────────────────────────────────────────────────────────────── */
  .score-display {
    display:flex; align-items:center; gap:6px;
    font-family:'Syne',sans-serif; font-size:18px; font-weight:700;
    background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.25);
    border-radius:10px; padding:6px 14px;
    transition: transform 0.2s;
  }
  .score-display .star { color:var(--accent3); }
  /* Animation de rebond quand le score augmente */
  .score-display.bump { animation: scoreBump 0.35s cubic-bezier(0.34,1.56,0.64,1); }
  @keyframes scoreBump {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.25); }
    100% { transform: scale(1); }
  }

  /* ── TIMER ── */
  .timer-wrap { margin-bottom:28px; }
  .timer-bar-bg { width:100%; height:6px; background:var(--surface2); border-radius:100px; overflow:hidden; margin-bottom:8px; }
  .timer-bar {
    height:100%; border-radius:100px;
    background:linear-gradient(90deg,var(--accent2),var(--accent));
    transition:width 1s linear, background 0.5s;
  }
  .timer-bar.warning { background:linear-gradient(90deg,var(--accent3),var(--wrong)); }
  .timer-text { display:flex; justify-content:space-between; font-size:13px; color:var(--text-muted); }

  /* ── PROGRESS DOTS ── */
  .progress-dots { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:28px; }
  .pdot { width:28px; height:6px; border-radius:100px; background:var(--surface2); transition:all 0.3s; }
  .pdot.current { background:var(--accent); width:40px; box-shadow:0 0 10px var(--accent); }
  .pdot.correct { background:var(--correct); }
  .pdot.wrong   { background:var(--wrong); }

  /* ── QUESTION ── */
  .question-num { font-size:12px; color:var(--text-muted); font-weight:600; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:12px; }
  .question-text { font-family:'Syne',sans-serif; font-size:clamp(20px,3vw,26px); font-weight:700; line-height:1.3; margin-bottom:32px; letter-spacing:-0.01em; }

  /* ── OPTIONS ── */
  .options-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:28px; }
  .option-btn {
    background:var(--surface2); border:2px solid var(--border); border-radius:14px;
    padding:18px 20px; cursor:pointer; text-align:left; color:var(--text);
    font-family:'DM Sans',sans-serif; font-size:15px; font-weight:400;
    transition:all 0.2s; display:flex; align-items:center; gap:14px;
    position:relative; overflow:hidden;
  }
  .option-btn::before {
    content:''; position:absolute; inset:0;
    background:linear-gradient(135deg,rgba(124,58,237,0.1),transparent);
    opacity:0; transition:opacity 0.2s;
  }
  .option-btn:hover:not(:disabled)::before { opacity:1; }
  .option-btn:hover:not(:disabled) { border-color:rgba(124,58,237,0.5); transform:translateY(-1px); }
  .option-btn:disabled { cursor:default; }

  .opt-letter {
    width:32px; height:32px; border-radius:8px;
    background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);
    display:flex; align-items:center; justify-content:center;
    font-family:'Syne',sans-serif; font-size:13px; font-weight:700;
    flex-shrink:0; transition:all 0.2s;
  }

  /* ─────────────────────────────────────────────────────────────────────
     ÉTAPE 3 — INSTRUCTION 2 : Comparaison réponse ↔ bonne réponse
     Les classes .correct et .wrong sont appliquées après comparaison
     ───────────────────────────────────────────────────────────────────── */
  .option-btn.correct { border-color:var(--correct); background:rgba(16,185,129,0.1); }
  .option-btn.correct .opt-letter { background:var(--correct); border-color:var(--correct); color:white; }
  .option-btn.wrong   { border-color:var(--wrong);   background:rgba(239,68,68,0.1); }
  .option-btn.wrong   .opt-letter { background:var(--wrong);   border-color:var(--wrong);   color:white; }
  .option-btn.selected-correct { animation:bounceCorrect 0.5s; }
  .option-btn.selected-wrong   { animation:shakeWrong 0.4s; }
  @keyframes bounceCorrect { 0%{transform:scale(1)} 40%{transform:scale(1.04)} 100%{transform:scale(1)} }
  @keyframes shakeWrong { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 60%{transform:translateX(6px)} }

  /* ─────────────────────────────────────────────────────────────────────
     ÉTAPE 3 — INSTRUCTION 3 : Retour visuel par question (correct/incorrect)
     ───────────────────────────────────────────────────────────────────── */
  .feedback-panel {
    border-radius:14px; padding:20px 24px; margin-bottom:20px;
    display:none; animation:fadeUp 0.3s;
    border:1px solid var(--border);
  }
  .feedback-panel.show { display:flex; align-items:flex-start; gap:16px; }
  /* Couleur de fond selon résultat */
  .feedback-panel.feedback-correct {
    background: rgba(16,185,129,0.08);
    border-color: rgba(16,185,129,0.35);
  }
  .feedback-panel.feedback-wrong {
    background: rgba(239,68,68,0.08);
    border-color: rgba(239,68,68,0.35);
  }
  .feedback-panel.feedback-timeout {
    background: rgba(245,158,11,0.08);
    border-color: rgba(245,158,11,0.35);
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

  .feedback-icon { font-size:28px; flex-shrink:0; }
  .feedback-body { flex:1; }
  .feedback-title { font-family:'Syne',sans-serif; font-weight:700; font-size:16px; margin-bottom:4px; }
  .feedback-title.correct-text { color:var(--correct); }
  .feedback-title.wrong-text   { color:var(--wrong); }
  .feedback-title.timeout-text { color:var(--accent3); }
  .feedback-explain { font-size:14px; color:var(--text-muted); line-height:1.5; }

  /* Badge de points gagnés affiché après bonne réponse */
  .points-badge {
    display:inline-flex; align-items:center; gap:4px;
    background:rgba(16,185,129,0.15); border:1px solid rgba(16,185,129,0.3);
    color:var(--correct); border-radius:20px; padding:3px 10px;
    font-size:13px; font-weight:700; margin-top:6px;
  }

  .quiz-actions { display:flex; gap:12px; }

  /* ─────────────────────────────────────────────────────────────────────
     ÉTAPE 3 — INSTRUCTION 4 : Écran de résultats — score + retours
     ───────────────────────────────────────────────────────────────────── */
  .result-hero { text-align:center; margin-bottom:48px; }

  .score-ring-wrap { position:relative; width:180px; height:180px; margin:0 auto 28px; }
  .score-ring-svg { transform:rotate(-90deg); }
  .score-ring-bg  { fill:none; stroke:var(--surface2); stroke-width:12; }
  .score-ring-fill {
    fill:none; stroke-width:12; stroke-linecap:round;
    stroke-dasharray:502; stroke-dashoffset:502;
    transition:stroke-dashoffset 1.5s cubic-bezier(0.34,1.56,0.64,1);
  }
  .score-ring-inner {
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
  }
  .score-pct { font-family:'Syne',sans-serif; font-size:44px; font-weight:800; line-height:1; letter-spacing:-0.04em; }
  .score-pct-label { font-size:12px; color:var(--text-muted); margin-top:4px; }

  .result-title    { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; margin-bottom:8px; }
  .result-subtitle { color:var(--text-muted); font-size:16px; }

  /* Panneau du score total mis en avant (Instruction 4) */
  .final-score-banner {
    display:flex; align-items:center; justify-content:center; gap:16px;
    background:linear-gradient(135deg,rgba(124,58,237,0.15),rgba(6,182,212,0.1));
    border:1px solid rgba(124,58,237,0.3);
    border-radius:16px; padding:20px 28px; margin-bottom:32px;
    text-align:center;
  }
  .final-score-value {
    font-family:'Syne',sans-serif; font-size:48px; font-weight:800;
    background:linear-gradient(135deg,#7c3aed,#06b6d4);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    line-height:1;
  }
  .final-score-label { font-size:14px; color:var(--text-muted); margin-top:4px; }

  .stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:32px; }
  .stat-card {
    background:var(--surface2); border:1px solid var(--border);
    border-radius:14px; padding:20px; text-align:center;
  }
  .stat-value { font-family:'Syne',sans-serif; font-size:32px; font-weight:800; line-height:1; margin-bottom:6px; }
  .stat-label { font-size:13px; color:var(--text-muted); }
  .stat-card.good    .stat-value { color:var(--correct); }
  .stat-card.bad     .stat-value { color:var(--wrong); }
  .stat-card.neutral .stat-value { color:var(--accent2); }

  /* ── TABS ── */
  .tabs { display:flex; gap:4px; background:var(--surface2); border-radius:12px; padding:4px; margin-bottom:28px; }
  .tab-btn {
    flex:1; padding:10px; border:none; background:transparent; color:var(--text-muted);
    border-radius:8px; font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500;
    cursor:pointer; transition:all 0.2s;
  }
  .tab-btn.active { background:var(--surface); color:var(--text); box-shadow:0 2px 8px rgba(0,0,0,0.3); }
  .tab-content { display:none; }
  .tab-content.active { display:block; }

  /* ── STREAK ── */
  .streak-banner {
    display:flex; align-items:center; gap:12px;
    background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(239,68,68,0.1));
    border:1px solid rgba(245,158,11,0.3);
    border-radius:12px; padding:16px 20px; margin-bottom:24px;
    font-size:15px; font-weight:500;
  }
  .streak-fire { font-size:28px; }

  /* ─────────────────────────────────────────────────────────────────────
     ÉTAPE 3 — INSTRUCTION 3 & 4 : Révision par question avec retour
     Chaque carte affiche clairement si la réponse était correcte/incorrecte
     ───────────────────────────────────────────────────────────────────── */
  .review-item {
    background:var(--surface2); border:1px solid var(--border);
    border-radius:14px; padding:24px; margin-bottom:12px;
  }
  .review-item.correct-item { border-left:4px solid var(--correct); }
  .review-item.wrong-item   { border-left:4px solid var(--wrong); }

  /* Badge correct/incorrect en haut de chaque carte de révision */
  .review-status {
    display:inline-flex; align-items:center; gap:6px;
    border-radius:20px; padding:4px 12px; font-size:12px; font-weight:700;
    text-transform:uppercase; letter-spacing:0.05em; margin-bottom:10px;
  }
  .review-status.ok  { background:rgba(16,185,129,0.15); color:var(--correct); border:1px solid rgba(16,185,129,0.3); }
  .review-status.ko  { background:rgba(239,68,68,0.15);  color:var(--wrong);   border:1px solid rgba(239,68,68,0.3); }
  .review-status.sk  { background:rgba(245,158,11,0.15); color:var(--accent3); border:1px solid rgba(245,158,11,0.3); }

  .review-q { font-family:'Syne',sans-serif; font-weight:600; font-size:15px; margin-bottom:12px; line-height:1.4; }
  .review-answers { display:flex; flex-direction:column; gap:6px; }
  .review-ans {
    display:flex; align-items:center; gap:8px; font-size:14px;
    padding:8px 12px; border-radius:8px;
  }
  .review-ans.correct-ans { background:rgba(16,185,129,0.1); color:var(--correct); }
  .review-ans.wrong-ans   { background:rgba(239,68,68,0.1);  color:var(--wrong); }
  .review-ans.neutral-ans { color:var(--text-muted); }
  .review-num {
    display:inline-flex; align-items:center; justify-content:center;
    width:24px; height:24px; border-radius:6px;
    background:rgba(255,255,255,0.06); font-size:12px; font-weight:700; flex-shrink:0;
  }
  .review-exp {
    margin-top:12px; padding:10px 14px;
    background:rgba(124,58,237,0.08); border:1px solid rgba(124,58,237,0.15);
    border-radius:8px; font-size:13px; color:var(--text-muted); line-height:1.5;
  }
  .review-exp strong { color:#a78bfa; }

  .result-actions { display:flex; gap:12px; }

  /* ── CONFETTI ── */
  .confetti-container { position:fixed; inset:0; pointer-events:none; z-index:100; }
  .confetti-piece {
    position:absolute; width:10px; height:10px; top:-20px; border-radius:2px;
    animation:confettiFall linear forwards;
  }
  @keyframes confettiFall { to { transform:translateY(110vh) rotate(720deg); opacity:0; } }

  @media (max-width:600px) {
    .card { padding:28px 20px; border-radius:20px; }
    .category-grid { grid-template-columns:repeat(2,1fr); }
    .options-grid  { grid-template-columns:1fr; }
    .stats-grid    { grid-template-columns:1fr; }
    .result-actions { flex-direction:column; }
    h1 { font-size:40px; }
  }
</style>
</head>
<body>
<div class="bg-canvas">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>
<div class="confetti-container" id="confettiContainer"></div>

<div class="app">

  <!-- ══════════════════════════════════════════════════════════
       ÉCRAN D'ACCUEIL
  ══════════════════════════════════════════════════════════ -->
  <div class="screen active" id="homeScreen">
    <div class="card">
      <div class="home-badge">Quiz Master</div>
      <h1>Testez vos<br><span>connaissances</span></h1>
      <p class="home-desc">Choisissez une catégorie, sélectionnez votre niveau et prouvez votre expertise. Chaque bonne réponse rapporte des points !</p>

      <div class="cat-label">Catégorie</div>
      <div class="category-grid" id="catGrid">
        <button class="cat-btn" data-cat="science"><span class="cat-emoji">🔬</span>Sciences</button>
        <button class="cat-btn" data-cat="histoire"><span class="cat-emoji">🏛️</span>Histoire</button>
        <button class="cat-btn" data-cat="geo"><span class="cat-emoji">🌍</span>Géographie</button>
        <button class="cat-btn" data-cat="tech"><span class="cat-emoji">💻</span>Technologie</button>
        <button class="cat-btn" data-cat="culture"><span class="cat-emoji">🎨</span>Culture</button>
        <button class="cat-btn" data-cat="sport"><span class="cat-emoji">⚽</span>Sport</button>
      </div>

