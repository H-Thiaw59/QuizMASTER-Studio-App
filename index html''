      { q:"Quel pays a remporté le plus de médailles d'or aux JO de l'été ?", opts:["États-Unis","Russie/URSS","Chine","Grande-Bretagne"], ans:0, exp:"Les États-Unis dominent le bilan total des médailles d'or olympiques avec plus de 1 000 médailles d'or." },
      { q:"Qu'est-ce que le 'Fosbury Flop' en athlétisme ?", opts:["Technique de saut en hauteur","Style de lancement de disque","Technique de sprint","Départ en natation"], ans:0, exp:"Dick Fosbury a révolutionné le saut en hauteur aux JO 1968 avec son saut dos tourné à la barre." },
      { q:"Quelle équipe a remporté le plus de Ligues des Champions ?", opts:["Real Madrid","AC Milan","Bayern Munich","Liverpool"], ans:0, exp:"Le Real Madrid a remporté 14 fois la Ligue des Champions / Coupe d'Europe (record absolu)." },
      { q:"En boxe, combien de rounds comprend un combat de championnat du monde ?", opts:["12","15","10","8"], ans:0, exp:"Depuis 1988, les championnats du monde de boxe se disputent sur 12 rounds de 3 minutes." },
      { q:"Quel est l'équipement distinctif du polo ?", opts:["Maillet à long manche","Bâton coudé","Crosse incurvée","Raquette spéciale"], ans:0, exp:"Le polo se joue à cheval avec un maillet (mallet) à long manche flexible pour frapper la balle." },
      { q:"En curling, quel instrument mesure la distance des pierres ?", opts:["Le 'measuring device'","Le 'skip'","Le 'hammer'","Le 'broom'"], ans:0, exp:"Un 'measuring device' est utilisé pour déterminer quelle équipe a la pierre la plus proche du centre (bouton)." },
      { q:"Quel est le record du monde du saut en longueur établi depuis 1991 ?", opts:["8,95m par Mike Powell","8,90m par Bob Beamon","9,01m par Carl Lewis","8,87m par Ivan Pedroso"], ans:0, exp:"Mike Powell a établi le record mondial du saut en longueur avec 8,95m aux Mondiaux de Tokyo en 1991." },
      { q:"En voile, que désigne le terme 'mayday' ?", opts:["Signal international de détresse","Type de manœuvre","Direction du vent","Nom d'un nœud"], ans:0, exp:"Mayday (du français 'm'aidez') est le signal international de détresse radio, utilisé en mer et en aviation." },
    ]
  }
};

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 1 : SYSTÈME DE NOTATION
   Barème : points de base selon la difficulté + bonus de temps
   Difficulté :  Facile = 100 pts | Moyen = 150 pts | Difficile = 200 pts
   Bonus temps : jusqu'à +50 pts selon le temps restant
   ================================================================ */
const SCORING = {
  facile:    { base: 100, label: '×1 Facile' },
  moyen:     { base: 150, label: '×1.5 Moyen' },
  difficile: { base: 200, label: '×2 Difficile' },
};

/* ================================================================
   ÉTAT GLOBAL DE L'APPLICATION
   ================================================================ */
const state = {
  category:          null,
  difficulty:        'moyen',
  questions:         [],
  current:           0,
  score:             0,      // ← Instruction 1 : score cumulé
  answered:          [],     // ← Instruction 2 : historique des réponses
  startTime:         null,
  questionStartTime: null,
  timerInterval:     null,
  timeLeft:          20,
  maxTime:           20,
  streak:            0,
  maxStreak:         0,
  skipped:           0,
  timeData:          [],
};

/* ================================================================
   UTILITAIRES
   ================================================================ */
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* ================================================================
   AUDITEURS — ACCUEIL
   ================================================================ */
document.querySelectorAll('.cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    state.category = btn.dataset.cat;
    document.getElementById('startBtn').disabled = false;
  });
});

document.querySelectorAll('.diff-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    state.difficulty = btn.dataset.diff;
  });
});

document.getElementById('startBtn').addEventListener('click', startQuiz);
document.getElementById('nextBtn').addEventListener('click', nextQuestion);
document.getElementById('skipBtn').addEventListener('click', skipQuestion);
document.getElementById('retryBtn').addEventListener('click', retryQuiz);
document.getElementById('homeBtn').addEventListener('click', goHome);
document.getElementById('tabStats').addEventListener('click',  () => showTab('stats'));
document.getElementById('tabReview').addEventListener('click', () => showTab('review'));

/* ================================================================
   DÉMARRAGE DU QUIZ
   ================================================================ */
function startQuiz() {
  const pool = QUESTIONS[state.category][state.difficulty];
  state.questions = shuffle(pool).slice(0, 10);
  state.current   = 0;
  state.score     = 0;
  state.answered  = [];
  state.streak    = 0;
  state.maxStreak = 0;
  state.skipped   = 0;
  state.timeData  = [];
  state.startTime = Date.now();

  showScreen('quizScreen');
  buildProgressDots();
  showQuestion();
}

/* ================================================================
   POINTS DE PROGRESSION DYNAMIQUES
   ================================================================ */
function buildProgressDots() {
  const container = document.getElementById('progressDots');
  container.innerHTML = '';
  state.questions.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'pdot' + (i === 0 ? ' current' : '');
    dot.id = 'dot-' + i;
    container.appendChild(dot);
  });
}

/* ================================================================
   AFFICHAGE DYNAMIQUE DE LA QUESTION (Instruction 1, 2)
   ================================================================ */
function showQuestion() {
  const q   = state.questions[state.current];
  const num = state.current + 1;
  const tot = state.questions.length;

  document.getElementById('quizCatTag').textContent  = state.category.charAt(0).toUpperCase() + state.category.slice(1);
  document.getElementById('qCounter').textContent    = `Q ${num} / ${tot}`;
  document.getElementById('liveScore').textContent   = state.score;
  document.getElementById('questionNum').textContent = `Question ${num}`;
  document.getElementById('questionText').textContent = q.q;

  // Génération dynamique des options
  const grid    = document.getElementById('optionsGrid');
  grid.innerHTML = '';
  const letters  = ['A','B','C','D'];
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span>${opt}</span>`;
    btn.addEventListener('click', () => selectAnswer(i));
    grid.appendChild(btn);
  });

  // Réinitialisation du feedback
  const panel = document.getElementById('feedbackPanel');
  panel.classList.remove('show','feedback-correct','feedback-wrong','feedback-timeout');
  document.getElementById('nextBtn').disabled = true;
  document.getElementById('skipBtn').disabled = false;
  document.getElementById('pointsBadgeWrap').innerHTML = '';

  // Mise à jour des dots
  document.querySelectorAll('.pdot').forEach((d, i) => {
    d.classList.remove('current');
    if (i === state.current) d.classList.add('current');
  });

  startTimer();
  state.questionStartTime = Date.now();
}

/* ================================================================
   TIMER
   ================================================================ */
function startTimer() {
  clearInterval(state.timerInterval);
  state.timeLeft = state.maxTime;
  updateTimerUI();
  state.timerInterval = setInterval(() => {
    state.timeLeft--;
    updateTimerUI();
    if (state.timeLeft <= 0) {
      clearInterval(state.timerInterval);
      autoTimeout();
    }
  }, 1000);
}

function updateTimerUI() {
  const pct = (state.timeLeft / state.maxTime) * 100;
  const bar = document.getElementById('timerBar');
  bar.style.width = pct + '%';
  bar.className   = 'timer-bar' + (state.timeLeft <= 5 ? ' warning' : '');
  document.getElementById('timerText').textContent = state.timeLeft + 's';
}

function autoTimeout() {
  const q = state.questions[state.current];
  document.querySelectorAll('.option-btn').forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.ans) btn.classList.add('correct');
  });
  recordAnswer(-1, false, 0);
  showFeedback('timeout', q, -1, 0);
  document.getElementById('nextBtn').disabled = false;
  document.getElementById('skipBtn').disabled = true;
}

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 2 : COMPARAISON RÉPONSE vs BONNE RÉPONSE
   idx (réponse choisie) est comparé à q.ans (bonne réponse)
   → calcul du score uniquement si correct
   ================================================================ */
function selectAnswer(idx) {
  clearInterval(state.timerInterval);
  const q       = state.questions[state.current];
  const correct = (idx === q.ans);          // ← comparaison réponse vs bonne réponse
  const elapsed = (Date.now() - state.questionStartTime) / 1000;
  state.timeData.push(elapsed);

  // Coloration des boutons après comparaison
  document.querySelectorAll('.option-btn').forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.ans)               btn.classList.add('correct');
    if (i === idx && !correct)     btn.classList.add('wrong');
    if (i === idx && correct)      btn.classList.add('selected-correct');
    if (i === idx && !correct)     btn.classList.add('selected-wrong');
  });

  let pointsEarned = 0;

  if (correct) {
    /* ── Instruction 1 : calcul et ajout des points au score ── */
    pointsEarned = calculatePoints();
    state.score += pointsEarned;
    state.streak++;
    if (state.streak > state.maxStreak) state.maxStreak = state.streak;

    /* ── Instruction 4 : mise à jour du score affiché avec animation ── */
    document.getElementById('liveScore').textContent = state.score;
    const sd = document.getElementById('scoreDisplay');
    sd.classList.remove('bump');
    void sd.offsetWidth; // reflow pour relancer l'animation
    sd.classList.add('bump');
  } else {
    state.streak = 0;
  }

  recordAnswer(idx, correct, pointsEarned);

  /* ── Instruction 3 : affichage du retour par question ── */
  showFeedback(correct ? 'correct' : 'wrong', q, idx, pointsEarned);

  document.getElementById('nextBtn').disabled = false;
  document.getElementById('skipBtn').disabled = true;

  // Mise à jour du dot de progression
  const dot = document.getElementById('dot-' + state.current);
  dot.classList.remove('current');
  dot.classList.add(correct ? 'correct' : 'wrong');
}

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 1 : CALCUL DES POINTS
   Points de base (difficulté) + bonus proportionnel au temps restant
   ================================================================ */
function calculatePoints() {
  const base      = SCORING[state.difficulty].base;
  const timeBonus = Math.max(0, Math.floor((state.timeLeft / state.maxTime) * 50));
  return base + timeBonus;
}

/* ================================================================
   ENREGISTREMENT DE LA RÉPONSE (Instruction 2)
   Sauvegarde : question, réponse choisie, résultat, points gagnés
   ================================================================ */
function recordAnswer(idx, correct, points) {
  state.answered.push({
    q:       state.questions[state.current],
    selected: idx,
    correct,
    points,
  });
}

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 3 : RETOUR PAR QUESTION
   Affiche un panneau coloré indiquant correct / incorrect / timeout
   ================================================================ */
function showFeedback(type, q, idx, points) {
  const panel   = document.getElementById('feedbackPanel');
  const icon    = document.getElementById('feedbackIcon');
  const title   = document.getElementById('feedbackTitle');
  const explain = document.getElementById('feedbackExplain');
  const badge   = document.getElementById('pointsBadgeWrap');

  panel.classList.remove('feedback-correct','feedback-wrong','feedback-timeout');
  badge.innerHTML = '';

  if (type === 'correct') {
    panel.classList.add('feedback-correct');
    icon.textContent    = '✅';
    title.textContent   = 'Bonne réponse !';
    title.className     = 'feedback-title correct-text';
    /* Badge des points gagnés */
    badge.innerHTML = `<div class="points-badge">+${points} pts ★</div>`;
  } else if (type === 'wrong') {
    panel.classList.add('feedback-wrong');
    icon.textContent    = '❌';
    const bonne = q.opts[q.ans];
    title.textContent   = `Incorrect — La bonne réponse était : « ${bonne} »`;
    title.className     = 'feedback-title wrong-text';
  } else {
    panel.classList.add('feedback-timeout');
    icon.textContent    = '⏱️';
    const bonne = q.opts[q.ans];
    title.textContent   = `Temps écoulé — Réponse : « ${bonne} »`;
    title.className     = 'feedback-title timeout-text';
  }

  explain.textContent = q.exp;
  panel.classList.add('show');
}

/* ================================================================
   PASSER UNE QUESTION
   ================================================================ */
function skipQuestion() {
  clearInterval(state.timerInterval);
  state.skipped++;
  state.streak = 0;
  const q = state.questions[state.current];
  document.querySelectorAll('.option-btn').forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.ans) btn.classList.add('correct');
  });
  recordAnswer(-2, false, 0);
  const dot = document.getElementById('dot-' + state.current);
  dot.classList.remove('current');
  dot.classList.add('wrong');
  showFeedback('wrong', q, -2, 0);
  document.getElementById('nextBtn').disabled = false;
  document.getElementById('skipBtn').disabled = true;
}

/* ================================================================
   QUESTION SUIVANTE
   ================================================================ */
function nextQuestion() {
  state.current++;
  if (state.current >= state.questions.length) showResults();
  else showQuestion();
}

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 4 : AFFICHAGE DU SCORE ET DES RETOURS
   L'écran de résultats affiche le score total, le % de réussite
   et un retour détaillé pour chaque question
   ================================================================ */
function showResults() {
  clearInterval(state.timerInterval);
  const nbCorrect = state.answered.filter(a => a.correct).length;
  const total     = state.questions.length;
  const pct       = Math.round((nbCorrect / total) * 100);
  const avgTime   = state.timeData.length > 0
    ? Math.round(state.timeData.reduce((a, b) => a + b, 0) / state.timeData.length)
    : 0;

  showScreen('resultsScreen');

  /* ── Anneau de score ── */
  const ring        = document.getElementById('scoreRing');
  const dashOffset  = 502 - (pct / 100) * 502;
  const ringColor   = pct >= 80 ? '#10b981' : pct >= 50 ? '#f59e0b' : '#ef4444';
  ring.style.stroke = ringColor;
  setTimeout(() => { ring.style.strokeDashoffset = dashOffset; }, 100);

  /* ── Animation % ── */
  let displayed = 0;
  const interval = setInterval(() => {
    displayed = Math.min(displayed + 2, pct);
    document.getElementById('scorePct').textContent = displayed + '%';
    if (displayed >= pct) clearInterval(interval);
  }, 20);

  /* ── Score total affiché en grand (Instruction 4) ── */
  document.getElementById('finalScoreValue').textContent       = state.score;
  document.getElementById('difficultyMultiplier').textContent  = SCORING[state.difficulty].label;

  /* ── Titre selon résultat ── */
  let rTitle, rSubtitle;
  if (pct >= 90)      { rTitle = '🏆 Extraordinaire !';    rSubtitle = `Expert absolu ! Score : ${state.score} pts`; }
  else if (pct >= 75) { rTitle = '⭐ Excellent travail !'; rSubtitle = `Très belle performance ! Score : ${state.score} pts`; }
  else if (pct >= 60) { rTitle = '👍 Bien joué !';         rSubtitle = `Vous vous en êtes bien sorti ! Score : ${state.score} pts`; }
  else if (pct >= 40) { rTitle = '📚 Peut mieux faire';    rSubtitle = `Continuez à apprendre ! Score : ${state.score} pts`; }
  else                { rTitle = '💪 Courage !';            rSubtitle = `Réessayez, vous pouvez faire mieux ! Score : ${state.score} pts`; }

  document.getElementById('resultTitle').textContent    = rTitle;
  document.getElementById('resultSubtitle').textContent = rSubtitle;
  document.getElementById('correctCount').textContent   = nbCorrect;
  document.getElementById('wrongCount').textContent     = total - nbCorrect;
  document.getElementById('timeUsed').textContent       = avgTime + 's';

  /* ── Bannière de série ── */
  if (state.maxStreak >= 3) {
    document.getElementById('streakBanner').style.display = 'flex';
    document.getElementById('streakText').textContent     =
      `Meilleure série : ${state.maxStreak} bonnes réponses consécutives ! 🔥`;
  } else {
    document.getElementById('streakBanner').style.display = 'none';
  }

  /* ── Instruction 4 : Révision détaillée avec retour par question ── */
  buildReviewList();

  if (pct >= 80) launchConfetti();
}

/* ================================================================
   ÉTAPE 3 — INSTRUCTION 3 & 4 : LISTE DE RÉVISION DÉTAILLÉE
   Pour chaque question : badge correct/incorrect, réponses colorées
   et explication de la bonne réponse
   ================================================================ */
function buildReviewList() {
  const reviewList = document.getElementById('reviewList');
  reviewList.innerHTML = '';
  const letters = ['A','B','C','D'];

  state.answered.forEach((ans, i) => {
    const item = document.createElement('div');

    /* ── Instruction 2 : comparaison affichée visuellement ── */
    item.className = 'review-item ' + (ans.correct ? 'correct-item' : 'wrong-item');

    /* Badge de statut */
    let statusHtml;
    if (ans.correct) {
      statusHtml = `<span class="review-status ok">✅ Correct  +${ans.points} pts</span>`;
    } else if (ans.selected === -2) {
      statusHtml = `<span class="review-status sk">⏭️ Passée</span>`;
    } else {
      statusHtml = `<span class="review-status ko">❌ Incorrect  0 pt</span>`;
    }

    /* Réponses colorées selon comparaison (Instruction 2) */
    const answersHtml = ans.q.opts.map((opt, j) => {
      let cls = 'neutral-ans', icon = '○';
      if (j === ans.q.ans) { cls = 'correct-ans'; icon = '✓'; }
      if (j === ans.selected && j !== ans.q.ans) { cls = 'wrong-ans'; icon = '✗'; }
      return `<div class="review-ans ${cls}">
                <span class="review-num">${letters[j]}</span>${icon} ${opt}
              </div>`;
    }).join('');

    /* Explication (Instruction 3) */
    const expHtml = `<div class="review-exp"><strong>💡 Explication :</strong> ${ans.q.exp}</div>`;

    item.innerHTML = `
      ${statusHtml}
      <div class="review-q">${i + 1}. ${ans.q.q}</div>
      <div class="review-answers">${answersHtml}</div>
      ${expHtml}
    `;
    reviewList.appendChild(item);
  });
}

/* ================================================================
   ONGLETS
   ================================================================ */
function showTab(name) {
  document.getElementById('tabStats').classList.toggle('active',  name === 'stats');
  document.getElementById('tabReview').classList.toggle('active', name === 'review');
  document.getElementById('statsTab').classList.toggle('active',  name === 'stats');
  document.getElementById('reviewTab').classList.toggle('active', name === 'review');
}

/* ================================================================
   REJOUER / ACCUEIL
   ================================================================ */
function retryQuiz() { startQuiz(); }

function goHome() {
  clearInterval(state.timerInterval);
  showScreen('homeScreen');
  document.getElementById('confettiContainer').innerHTML = '';
  document.getElementById('streakBanner').style.display = 'none';
}

/* ================================================================
   CONFETTIS (score ≥ 80%)
   ================================================================ */
function launchConfetti() {
  const colors    = ['#7c3aed','#06b6d4','#f59e0b','#10b981','#ef4444','#ec4899'];
  const container = document.getElementById('confettiContainer');
  container.innerHTML = '';
  for (let i = 0; i < 80; i++) {
    const piece    = document.createElement('div');
    piece.className = 'confetti-piece';
    const color    = colors[Math.floor(Math.random() * colors.length)];
    const left     = Math.random() * 100;
    const duration = 1.5 + Math.random() * 2;
    const delay    = Math.random() * 1.5;
    const size     = 6 + Math.random() * 10;
    piece.style.cssText = `left:${left}%;background:${color};width:${size}px;height:${size}px;animation-duration:${duration}s;animation-delay:${delay}s;border-radius:${Math.random()>.5?'50%':'2px'};`;
    container.appendChild(piece);
    setTimeout(() => piece.remove(), (duration + delay) * 1000 + 500);
  }
}
