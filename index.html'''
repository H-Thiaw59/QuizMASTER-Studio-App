<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuizMaster Pro — Étape 4</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════════════
   DESIGN SYSTEM
═══════════════════════════════════════════════════════════════ */
:root {
  --bg:       #0a0a0f;
  --surface:  #12121a;
  --surface2: #1a1a26;
  --surface3: #22223a;
  --border:   rgba(255,255,255,0.07);
  --accent:   #7c3aed;
  --accent2:  #06b6d4;
  --accent3:  #f59e0b;
  --text:     #f0f0f8;
  --muted:    #6b7280;
  --correct:  #10b981;
  --wrong:    #ef4444;
  --r:        16px;

  /* Jokers */
  --j50:    #06b6d4;
  --jHint:  #f59e0b;
  --jDC:    #ec4899;
}

*  { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family:'DM Sans',sans-serif;
  background:var(--bg); color:var(--text);
  min-height:100vh; overflow-x:hidden;
}

/* ── animated BG ── */
.bg-canvas { position:fixed; inset:0; z-index:0; overflow:hidden; }
.orb {
  position:absolute; border-radius:50%;
  filter:blur(80px); opacity:0.15;
  animation:float 8s ease-in-out infinite;
}
.orb-1{width:500px;height:500px;background:var(--accent);top:-10%;left:-10%;animation-delay:0s}
.orb-2{width:400px;height:400px;background:var(--accent2);bottom:-5%;right:-5%;animation-delay:-3s}
.orb-3{width:300px;height:300px;background:var(--accent3);top:40%;left:60%;animation-delay:-6s}
@keyframes float{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(30px,-30px) scale(1.05)}66%{transform:translate(-20px,20px) scale(.95)}}
.bg-canvas::after{content:'';position:absolute;inset:0;opacity:.4;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E")}

.app {
  position:relative; z-index:1; min-height:100vh;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center; padding:24px;
}

/* ── SCREENS ── */
.screen{display:none;width:100%;max-width:760px;animation:slideIn .4s cubic-bezier(.34,1.56,.64,1)}
.screen.active{display:block}
@keyframes slideIn{from{opacity:0;transform:translateY(30px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}

/* ── CARD ── */
.card{
  background:var(--surface); border:1px solid var(--border);
  border-radius:24px; padding:48px; backdrop-filter:blur(20px);
  box-shadow:0 32px 80px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.05);
}

/* ═══════════════════════════════════════════════════════════════
   HOME SCREEN
═══════════════════════════════════════════════════════════════ */
.home-badge{
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(124,58,237,.15); border:1px solid rgba(124,58,237,.3);
  border-radius:100px; padding:6px 16px; font-size:13px; font-weight:500;
  color:#a78bfa; margin-bottom:32px; letter-spacing:.05em; text-transform:uppercase;
}
.home-badge::before{content:'✦'}

h1{font-family:'Syne',sans-serif;font-size:clamp(42px,8vw,76px);font-weight:800;line-height:.95;letter-spacing:-.03em;margin-bottom:20px}
h1 span{background:linear-gradient(135deg,#7c3aed,#06b6d4,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.home-desc{color:var(--muted);font-size:17px;line-height:1.6;max-width:500px;margin-bottom:40px}

.cat-label{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.category-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:28px}
.cat-btn{background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:18px 14px;cursor:pointer;transition:all .2s;text-align:center;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500}
.cat-btn .cat-emoji{font-size:26px;display:block;margin-bottom:6px}
.cat-btn:hover{border-color:var(--accent);background:rgba(124,58,237,.1);transform:translateY(-2px)}
.cat-btn.selected{border-color:var(--accent);background:rgba(124,58,237,.2);box-shadow:0 0 20px rgba(124,58,237,.3)}

.diff-row{display:flex;gap:10px;margin-bottom:24px}
.diff-btn{flex:1;padding:12px;border-radius:10px;border:1px solid var(--border);background:var(--surface2);color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;transition:all .2s;text-align:center}
.diff-btn:hover{border-color:rgba(255,255,255,.2);color:var(--text)}
.diff-btn[data-diff="facile"].selected{border-color:var(--correct);background:rgba(16,185,129,.15);color:var(--correct)}
.diff-btn[data-diff="moyen"].selected{border-color:var(--accent3);background:rgba(245,158,11,.15);color:var(--accent3)}
.diff-btn[data-diff="difficile"].selected{border-color:var(--wrong);background:rgba(239,68,68,.15);color:var(--wrong)}

/* ═══════════════════════════════════════════════════════════════
   ÉTAPE 4 — FONCTIONNALITÉ : MODE SUDDEN DEATH
═══════════════════════════════════════════════════════════════ */
.mode-row{display:flex;gap:10px;margin-bottom:32px}
.mode-btn{
  flex:1; padding:14px 12px; border-radius:12px; border:1px solid var(--border);
  background:var(--surface2); color:var(--muted); cursor:pointer;
  font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500;
  transition:all .2s; text-align:center; line-height:1.4;
}
.mode-btn:hover{border-color:rgba(255,255,255,.2);color:var(--text)}
.mode-btn .mode-icon{font-size:22px;display:block;margin-bottom:4px}
.mode-btn.selected.mode-normal{border-color:var(--accent2);background:rgba(6,182,212,.15);color:var(--accent2)}
.mode-btn.selected.mode-sd{border-color:var(--wrong);background:rgba(239,68,68,.15);color:var(--wrong)}

/* ── Feature strip ── */
.features-strip{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px}
.feat-pill{display:inline-flex;align-items:center;gap:5px;padding:6px 13px;border-radius:20px;font-size:12px;font-weight:600;cursor:default;transition:transform .15s;border:1px solid}
.feat-pill:hover{transform:translateY(-1px)}
.feat-joker{background:rgba(6,182,212,.12);border-color:rgba(6,182,212,.3);color:var(--j50)}
.feat-streak{background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.3);color:var(--wrong)}
.feat-badges{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--accent3)}
.feat-lb{background:rgba(124,58,237,.12);border-color:rgba(124,58,237,.3);color:#a78bfa}
.feat-chart{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);color:var(--correct)}
.feat-sd{background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.3);color:var(--wrong)}
.scoring-hint{font-size:11px;font-weight:400;color:var(--muted);letter-spacing:0;text-transform:none;font-family:'DM Sans',sans-serif}

/* ── BUTTONS ── */
.btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#5b21b6);color:white;border:none;border-radius:14px;padding:18px 36px;font-family:'Syne',sans-serif;font-size:16px;font-weight:700;letter-spacing:.02em;cursor:pointer;transition:all .2s;box-shadow:0 8px 32px rgba(124,58,237,.4);width:100%}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(124,58,237,.5)}
.btn-primary:active{transform:translateY(0)}
.btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none}

.btn-secondary{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:14px;padding:14px 24px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;cursor:pointer;transition:all .2s}
.btn-secondary:hover{border-color:rgba(255,255,255,.2);color:var(--text)}

/* ═══════════════════════════════════════════════════════════════
   QUIZ SCREEN
═══════════════════════════════════════════════════════════════ */
.quiz-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;gap:12px}
.quiz-meta{display:flex;align-items:center;gap:12px;flex-shrink:0}
.quiz-cat-tag{background:rgba(124,58,237,.2);border:1px solid rgba(124,58,237,.3);color:#a78bfa;border-radius:8px;padding:4px 12px;font-size:12px;font-weight:600;letter-spacing:.05em;text-transform:uppercase}
.q-counter{font-size:14px;color:var(--muted);font-weight:500}

/* Score live */
.score-display{display:flex;align-items:center;gap:6px;font-family:'Syne',sans-serif;font-size:17px;font-weight:700;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);border-radius:10px;padding:6px 14px;transition:transform .2s;flex-shrink:0}
.score-display .star{color:var(--accent3)}
.score-display.bump{animation:scoreBump .35s cubic-bezier(.34,1.56,.64,1)}
@keyframes scoreBump{0%{transform:scale(1)}50%{transform:scale(1.3)}100%{transform:scale(1)}}

/* ── Streak multiplier badge ── */
.streak-badge{
  display:none; align-items:center; gap:4px;
  background:linear-gradient(135deg,rgba(239,68,68,.2),rgba(245,158,11,.2));
  border:1px solid rgba(239,68,68,.4);
  border-radius:8px; padding:4px 10px;
  font-family:'Syne',sans-serif; font-size:13px; font-weight:700;
  color:#fca5a5; flex-shrink:0;
  animation:pulseStreak 1.5s ease-in-out infinite;
}
.streak-badge.visible{display:flex}
@keyframes pulseStreak{0%,100%{opacity:1}50%{opacity:.6}}

/* Timer */
.timer-wrap{margin-bottom:20px}
.timer-bar-bg{width:100%;height:6px;background:var(--surface2);border-radius:100px;overflow:hidden;margin-bottom:6px}
.timer-bar{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--accent2),var(--accent));transition:width 1s linear,background .5s}
.timer-bar.warning{background:linear-gradient(90deg,var(--accent3),var(--wrong))}
.timer-text{display:flex;justify-content:space-between;font-size:12px;color:var(--muted)}

/* Progress dots */
.progress-dots{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
.pdot{width:28px;height:6px;border-radius:100px;background:var(--surface2);transition:all .3s}
.pdot.current{background:var(--accent);width:40px;box-shadow:0 0 10px var(--accent)}
.pdot.correct{background:var(--correct)}
.pdot.wrong{background:var(--wrong)}

/* Question */
.question-num{font-size:12px;color:var(--muted);font-weight:600;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}
.question-text{font-family:'Syne',sans-serif;font-size:clamp(18px,3vw,24px);font-weight:700;line-height:1.3;margin-bottom:24px;letter-spacing:-.01em}

/* ═══════════════════════════════════════════════════════════════
   ÉTAPE 4 — FONCTIONNALITÉ : JOKERS (BOUÉES DE SAUVETAGE)
═══════════════════════════════════════════════════════════════ */
.lifelines-bar{
  display:flex; gap:10px; margin-bottom:20px;
  padding:14px 16px;
  background:var(--surface2); border:1px solid var(--border);
  border-radius:14px; align-items:center;
}
.lifelines-label{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-right:4px;flex-shrink:0}
.ll-btn{
  display:flex; align-items:center; gap:6px;
  padding:8px 14px; border-radius:10px; border:none; cursor:pointer;
  font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600;
  transition:all .2s; position:relative;
}
.ll-btn:disabled{opacity:.3;cursor:not-allowed;filter:grayscale(1)}
.ll-btn-5050{background:rgba(6,182,212,.15);color:var(--j50);border:1px solid rgba(6,182,212,.35)}
.ll-btn-5050:hover:not(:disabled){background:rgba(6,182,212,.25);transform:translateY(-1px)}
.ll-btn-hint{background:rgba(245,158,11,.15);color:var(--jHint);border:1px solid rgba(245,158,11,.35)}
.ll-btn-hint:hover:not(:disabled){background:rgba(245,158,11,.25);transform:translateY(-1px)}
.ll-btn-dc{background:rgba(236,72,153,.15);color:var(--jDC);border:1px solid rgba(236,72,153,.35)}
.ll-btn-dc:hover:not(:disabled){background:rgba(236,72,153,.25);transform:translateY(-1px)}
.ll-used-dot{width:7px;height:7px;border-radius:50%;background:currentColor;opacity:.5}

/* Hint panel */
.hint-panel{
  background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.25);
  border-radius:12px; padding:14px 18px; margin-bottom:16px;
  display:none; animation:fadeUp .3s;
}
.hint-panel.show{display:flex;align-items:flex-start;gap:10px}
.hint-icon{font-size:20px;flex-shrink:0}
.hint-text{font-size:14px;color:var(--accent3);line-height:1.5}

/* Double Chance badge */
.dc-badge{
  display:none; align-items:center; gap:6px;
  background:rgba(236,72,153,.12); border:1px solid rgba(236,72,153,.3);
  border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600;
  color:var(--jDC); margin-bottom:12px;
}
.dc-badge.show{display:flex}

/* Options */
.options-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.option-btn{
  background:var(--surface2); border:2px solid var(--border); border-radius:14px;
  padding:16px 18px; cursor:pointer; text-align:left; color:var(--text);
  font-family:'DM Sans',sans-serif; font-size:14px; font-weight:400;
  transition:all .2s; display:flex; align-items:center; gap:12px;
  position:relative; overflow:hidden;
}
.option-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(124,58,237,.1),transparent);opacity:0;transition:opacity .2s}
.option-btn:hover:not(:disabled)::before{opacity:1}
.option-btn:hover:not(:disabled){border-color:rgba(124,58,237,.5);transform:translateY(-1px)}
.option-btn:disabled{cursor:default}
.option-btn.eliminated{opacity:.2;pointer-events:none}

.opt-letter{width:30px;height:30px;border-radius:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;flex-shrink:0;transition:all .2s}
.option-btn.correct{border-color:var(--correct);background:rgba(16,185,129,.1)}
.option-btn.correct .opt-letter{background:var(--correct);border-color:var(--correct);color:white}
.option-btn.wrong{border-color:var(--wrong);background:rgba(239,68,68,.1)}
.option-btn.wrong .opt-letter{background:var(--wrong);border-color:var(--wrong);color:white}
.option-btn.selected-correct{animation:bounceCorrect .5s}
.option-btn.selected-wrong{animation:shakeWrong .4s}
@keyframes bounceCorrect{0%{transform:scale(1)}40%{transform:scale(1.04)}100%{transform:scale(1)}}
@keyframes shakeWrong{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}60%{transform:translateX(6px)}}

/* Feedback */
.feedback-panel{border-radius:14px;padding:18px 22px;margin-bottom:16px;display:none;animation:fadeUp .3s;border:1px solid var(--border)}
.feedback-panel.show{display:flex;align-items:flex-start;gap:14px}
.feedback-panel.feedback-correct{background:rgba(16,185,129,.08);border-color:rgba(16,185,129,.35)}
.feedback-panel.feedback-wrong{background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.35)}
.feedback-panel.feedback-timeout{background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.35)}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.feedback-icon{font-size:26px;flex-shrink:0}
.feedback-body{flex:1}
.feedback-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:4px}
.feedback-title.correct-text{color:var(--correct)}
.feedback-title.wrong-text{color:var(--wrong)}
.feedback-title.timeout-text{color:var(--accent3)}
.feedback-explain{font-size:13px;color:var(--muted);line-height:1.5}
.points-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:var(--correct);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:700;margin-top:5px}

.quiz-actions{display:flex;gap:10px}

/* ═══════════════════════════════════════════════════════════════
   RÉSULTATS
═══════════════════════════════════════════════════════════════ */
.result-hero{text-align:center;margin-bottom:40px}
.score-ring-wrap{position:relative;width:170px;height:170px;margin:0 auto 24px}
.score-ring-svg{transform:rotate(-90deg)}
.score-ring-bg{fill:none;stroke:var(--surface2);stroke-width:12}
.score-ring-fill{fill:none;stroke-width:12;stroke-linecap:round;stroke-dasharray:502;stroke-dashoffset:502;transition:stroke-dashoffset 1.5s cubic-bezier(.34,1.56,.64,1)}
.score-ring-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.score-pct{font-family:'Syne',sans-serif;font-size:42px;font-weight:800;line-height:1;letter-spacing:-.04em}
.score-pct-label{font-size:11px;color:var(--muted);margin-top:4px}
.result-title{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;margin-bottom:8px}
.result-subtitle{color:var(--muted);font-size:15px}

/* Score banner */
.final-score-banner{display:flex;align-items:center;justify-content:center;gap:20px;background:linear-gradient(135deg,rgba(124,58,237,.15),rgba(6,182,212,.1));border:1px solid rgba(124,58,237,.3);border-radius:16px;padding:20px 28px;margin-bottom:28px;text-align:center}
.final-score-value{font-family:'Syne',sans-serif;font-size:46px;font-weight:800;background:linear-gradient(135deg,#7c3aed,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.final-score-label{font-size:13px;color:var(--muted);margin-top:4px}
.divider-v{width:1px;height:50px;background:var(--border)}

/* ═══════════════════════════════════════════════════════════════
   ÉTAPE 4 — FONCTIONNALITÉ : BADGES / ACHIEVEMENTS
═══════════════════════════════════════════════════════════════ */
.achievements-section{margin-bottom:28px}
.achievements-title{font-size:12px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
.achievements-grid{display:flex;flex-wrap:wrap;gap:8px}
.ach-badge{
  display:flex; align-items:center; gap:8px;
  padding:8px 14px; border-radius:30px; font-size:13px; font-weight:600;
  animation:popIn .4s cubic-bezier(.34,1.56,.64,1);
}
.ach-badge.locked{opacity:.25;filter:grayscale(1);background:var(--surface2);border:1px solid var(--border);color:var(--muted)}
.ach-badge.unlocked{border:1px solid;animation:popIn .4s cubic-bezier(.34,1.56,.64,1)}
.ach-icon{font-size:18px}
@keyframes popIn{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}

/* Couleurs par badge */
.ach-gold{background:rgba(245,158,11,.15);border-color:rgba(245,158,11,.4);color:var(--accent3)}
.ach-green{background:rgba(16,185,129,.15);border-color:rgba(16,185,129,.4);color:var(--correct)}
.ach-purple{background:rgba(124,58,237,.15);border-color:rgba(124,58,237,.4);color:#a78bfa}
.ach-red{background:rgba(239,68,68,.15);border-color:rgba(239,68,68,.4);color:var(--wrong)}
.ach-cyan{background:rgba(6,182,212,.15);border-color:rgba(6,182,212,.4);color:var(--accent2)}
.ach-pink{background:rgba(236,72,153,.15);border-color:rgba(236,72,153,.4);color:#f9a8d4}

/* ── Stat cards ── */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px}
.stat-card{background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:18px;text-align:center}
.stat-value{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;line-height:1;margin-bottom:5px}
.stat-label{font-size:12px;color:var(--muted)}
.stat-card.good .stat-value{color:var(--correct)}
.stat-card.bad  .stat-value{color:var(--wrong)}
.stat-card.neutral .stat-value{color:var(--accent2)}

/* ── streak banner ── */
.streak-banner-res{display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,rgba(245,158,11,.15),rgba(239,68,68,.1));border:1px solid rgba(245,158,11,.3);border-radius:12px;padding:14px 18px;margin-bottom:20px;font-size:14px;font-weight:500}
.streak-fire{font-size:26px}

/* ─── TABS ─── */
.tabs{display:flex;gap:4px;background:var(--surface2);border-radius:12px;padding:4px;margin-bottom:24px}
.tab-btn{flex:1;padding:10px;border:none;background:transparent;color:var(--muted);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s}
.tab-btn.active{background:var(--surface);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,.3)}
.tab-content{display:none}
.tab-content.active{display:block}

/* ═══════════════════════════════════════════════════════════════
   ÉTAPE 4 — FONCTIONNALITÉ : CLASSEMENT (LEADERBOARD)
═══════════════════════════════════════════════════════════════ */
.leaderboard-list{display:flex;flex-direction:column;gap:8px}
.lb-entry{
  display:flex; align-items:center; gap:14px;
  background:var(--surface2); border:1px solid var(--border);
  border-radius:12px; padding:14px 18px; transition:all .2s;
  position:relative; overflow:hidden;
}
.lb-entry.is-current{border-color:rgba(124,58,237,.5);background:rgba(124,58,237,.08)}
.lb-entry.is-current::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent)}
.lb-rank{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;width:36px;flex-shrink:0;text-align:center}
.lb-rank.gold{color:var(--accent3)}
.lb-rank.silver{color:#94a3b8}
.lb-rank.bronze{color:#a16207}
.lb-info{flex:1}
.lb-name{font-weight:600;font-size:14px}
.lb-meta{font-size:12px;color:var(--muted);margin-top:2px}
.lb-score{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--accent3)}
.lb-badge{font-size:18px}
.lb-empty{text-align:center;padding:32px;color:var(--muted);font-size:14px}

/* ═══════════════════════════════════════════════════════════════
   ÉTAPE 4 — FONCTIONNALITÉ : GRAPHIQUE DE PROGRESSION
═══════════════════════════════════════════════════════════════ */
.progress-chart{background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:24px}
.chart-title{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:80px}
.chart-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.chart-bar{width:100%;border-radius:4px 4px 0 0;transition:height .8s cubic-bezier(.34,1.56,.64,1);min-height:4px}
.chart-bar.bar-correct{background:linear-gradient(180deg,var(--correct),rgba(16,185,129,.4))}
.chart-bar.bar-wrong{background:linear-gradient(180deg,var(--wrong),rgba(239,68,68,.4))}
.chart-bar.bar-skip{background:linear-gradient(180deg,var(--accent3),rgba(245,158,11,.4))}
.chart-label{font-size:10px;color:var(--muted);font-weight:600}

/* Révision */
.review-item{background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:10px}
.review-item.correct-item{border-left:4px solid var(--correct)}
.review-item.wrong-item{border-left:4px solid var(--wrong)}
.review-status{display:inline-flex;align-items:center;gap:6px;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.review-status.ok{background:rgba(16,185,129,.15);color:var(--correct);border:1px solid rgba(16,185,129,.3)}
.review-status.ko{background:rgba(239,68,68,.15);color:var(--wrong);border:1px solid rgba(239,68,68,.3)}
.review-status.sk{background:rgba(245,158,11,.15);color:var(--accent3);border:1px solid rgba(245,158,11,.3)}
.review-q{font-family:'Syne',sans-serif;font-weight:600;font-size:14px;margin-bottom:10px;line-height:1.4}
.review-answers{display:flex;flex-direction:column;gap:5px}
.review-ans{display:flex;align-items:center;gap:8px;font-size:13px;padding:7px 11px;border-radius:7px}
.review-ans.correct-ans{background:rgba(16,185,129,.1);color:var(--correct)}
.review-ans.wrong-ans{background:rgba(239,68,68,.1);color:var(--wrong)}
.review-ans.neutral-ans{color:var(--muted)}
.review-num{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:5px;background:rgba(255,255,255,.06);font-size:11px;font-weight:700;flex-shrink:0}
.review-exp{margin-top:10px;padding:10px 13px;background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.15);border-radius:7px;font-size:12px;color:var(--muted);line-height:1.5}
.review-exp strong{color:#a78bfa}

.result-actions{display:flex;gap:12px}

/* ── SUDDEN DEATH overlay ── */
.sd-overlay{
  position:fixed;inset:0;z-index:999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(10,10,15,.95);backdrop-filter:blur(8px);
  animation:fadeIn .3s;
}
.sd-overlay.hidden{display:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.sd-content{text-align:center;max-width:400px;padding:24px}
.sd-icon{font-size:80px;margin-bottom:20px;animation:sdShake .5s}
@keyframes sdShake{0%,100%{transform:rotate(0)}25%{transform:rotate(-10deg)}75%{transform:rotate(10deg)}}
.sd-title{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:var(--wrong);margin-bottom:12px}
.sd-sub{color:var(--muted);font-size:16px;line-height:1.5;margin-bottom:28px}

/* ── Toast de achievement ── */
.toast-container{position:fixed;top:20px;right:20px;z-index:500;display:flex;flex-direction:column;gap:8px}
.toast{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;padding:14px 18px;
  display:flex;align-items:center;gap:12px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
  animation:toastIn .4s cubic-bezier(.34,1.56,.64,1) forwards;
  min-width:280px;max-width:320px;
}
.toast.toast-out{animation:toastOut .3s ease forwards}
@keyframes toastIn{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes toastOut{from{transform:translateX(0);opacity:1}to{transform:translateX(110%);opacity:0}}
.toast-icon{font-size:24px;flex-shrink:0}
.toast-body .toast-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px}
.toast-body .toast-sub{font-size:12px;color:var(--muted);margin-top:2px}

/* Confetti */
.confetti-container{position:fixed;inset:0;pointer-events:none;z-index:100}
.confetti-piece{position:absolute;width:10px;height:10px;top:-20px;border-radius:2px;animation:confettiFall linear forwards}
@keyframes confettiFall{to{transform:translateY(110vh) rotate(720deg);opacity:0}}

@media(max-width:600px){
  .card{padding:24px 16px;border-radius:18px}
  .category-grid{grid-template-columns:repeat(2,1fr)}
  .options-grid{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:1fr}
  .result-actions{flex-direction:column}
  h1{font-size:38px}
  .lifelines-bar{flex-wrap:wrap}
}
</style>
</head>
