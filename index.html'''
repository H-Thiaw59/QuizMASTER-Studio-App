/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 1 : FONCTIONNALITÉS IDENTIFIÉES
   ① Jokers : 50:50 | Indice | Double Chance
   ② Classement (Leaderboard) avec session de jeu
   ③ Multiplicateur de série (×1, ×1.5, ×2)
   ④ Badges / Achievements débloqués selon performance
   ⑤ Graphique de progression par question
   ⑥ Mode Sudden Death
════════════════════════════════════════════════════════════════ */

/* ── Barème ── */
const SCORING = {
  facile:   {base:100, label:'😊 Facile'},
  moyen:    {base:150, label:'🎯 Moyen'},
  difficile:{base:200, label:'🔥 Difficile'},
};

/* ── Définition des Achievements avec descriptions complètes ── */
const ACHIEVEMENTS = [
  {id:'perfect',    icon:'🏆', label:'Score parfait',       desc:'10/10 — aucune erreur !',                         color:'ach-gold',   test:(s)=>s.pct===100},
  {id:'speed',      icon:'⚡', label:'Éclair',              desc:'Réponse moyenne ≤ 5 s avec ≥ 60 % de réussite',   color:'ach-cyan',   test:(s)=>s.avgTime<=5 && s.pct>=60},
  {id:'streak5',    icon:'🔥', label:'Série enflammée',     desc:'5 bonnes réponses consécutives ou plus',           color:'ach-red',    test:(s)=>s.maxStreak>=5},
  {id:'noLifeline', icon:'💪', label:'Sans filet',          desc:'≥ 70 % sans utiliser aucun joker',                color:'ach-purple', test:(s)=>s.lifesUsed===0 && s.pct>=70},
  {id:'scholar',    icon:'🎓', label:'Grand Savant',        desc:'≥ 80 % de bonnes réponses',                       color:'ach-green',  test:(s)=>s.pct>=80},
  {id:'survivor',   icon:'💀', label:'Survivant',           desc:'10/10 en mode Sudden Death',                      color:'ach-red',    test:(s)=>s.mode==='sudden_death' && s.pct===100},
  {id:'quick10',    icon:'🚀', label:'Quiz Éclair',         desc:'Score parfait en moins de 8 s par question',      color:'ach-cyan',   test:(s)=>s.pct===100 && s.avgTime<=8},
  {id:'comeback',   icon:'🔄', label:'Comeback',            desc:'≥ 60 % en commençant par une mauvaise réponse',   color:'ach-pink',   test:(s)=>s.pct>=60 && s.answered[0]?.correct===false},
];

/* ── Classement session (stocké en mémoire) ── */
let leaderboard = [];

/* ── État global ── */
const state = {
  category:null, difficulty:'moyen', mode:'normal',
  questions:[], current:0, score:0, answered:[],
  startTime:null, questionStartTime:null,
  timerInterval:null, timeLeft:20, maxTime:20,
  streak:0, maxStreak:0, skipped:0, timeData:[],
  /* Jokers */
  lifelines:{fiftyfifty:true, hint:true, doublechance:true},
  dcActive:false,          // double chance en cours
  dcFirstWrong:false,      // premier mauvais choix avec DC
  lifesUsed:0,             // nb jokers utilisés
  /* Mode */
  isSuddenDeath:false,
  sdTriggered:false,
};

/* ════════════════════════════════════════════════════════════════
   UTILITAIRES
════════════════════════════════════════════════════════════════ */
function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* ════════════════════════════════════════════════════════════════
   AUDITEURS — ACCUEIL
════════════════════════════════════════════════════════════════ */
document.querySelectorAll('.cat-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    state.category=btn.dataset.cat;
    const sb=document.getElementById('startBtn');
    sb.disabled=false;
    sb.textContent='Commencer le Quiz →';
  });
});
document.querySelectorAll('.diff-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.diff-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    state.difficulty=btn.dataset.diff;
  });
});
document.querySelectorAll('.mode-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    state.mode=btn.dataset.mode;
  });
});
document.getElementById('startBtn').addEventListener('click',startQuiz);
document.getElementById('nextBtn').addEventListener('click',nextQuestion);
document.getElementById('skipBtn').addEventListener('click',skipQuestion);
document.getElementById('retryBtn').addEventListener('click',retryQuiz);
document.getElementById('homeBtn').addEventListener('click',goHome);
document.getElementById('tabStats').addEventListener('click',()=>showTab('stats'));
document.getElementById('tabChart').addEventListener('click',()=>showTab('chart'));
document.getElementById('tabReview').addEventListener('click',()=>showTab('review'));
document.getElementById('tabLB').addEventListener('click',()=>showTab('lb'));

/* ── Jokers ── */
document.getElementById('ll5050').addEventListener('click',useLifeline5050);
document.getElementById('llHint').addEventListener('click',useLifelineHint);
document.getElementById('llDC').addEventListener('click',useLifelineDC);

/* ── Sudden Death buttons ── */
document.getElementById('sdHome').addEventListener('click',()=>{document.getElementById('sdOverlay').classList.add('hidden');goHome()});
document.getElementById('sdResults').addEventListener('click',()=>{document.getElementById('sdOverlay').classList.add('hidden');showResults()});

/* ════════════════════════════════════════════════════════════════
   DÉMARRAGE
════════════════════════════════════════════════════════════════ */
function startQuiz(){
  const pool=QUESTIONS[state.category][state.difficulty];
  state.questions=shuffle(pool).slice(0,10);
  state.current=0; state.score=0; state.answered=[];
  state.streak=0; state.maxStreak=0; state.skipped=0; state.timeData=[];
  state.lifelines={fiftyfifty:true,hint:true,doublechance:true};
  state.dcActive=false; state.lifesUsed=0; state.sdTriggered=false;
  state.isSuddenDeath=(state.mode==='sudden_death');
  state.startTime=Date.now();

  updateLifelineButtons();
  showScreen('quizScreen');
  buildProgressDots();
  showQuestion();
}

/* ── Points de progression ── */
function buildProgressDots(){
  const c=document.getElementById('progressDots');
  c.innerHTML='';
  state.questions.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='pdot'+(i===0?' current':'');
    d.id='dot-'+i;
    c.appendChild(d);
  });
}

/* ════════════════════════════════════════════════════════════════
   AFFICHAGE QUESTION
════════════════════════════════════════════════════════════════ */
function showQuestion(){
  const q=state.questions[state.current];
  const num=state.current+1, tot=state.questions.length;

  document.getElementById('quizCatTag').textContent=state.category.charAt(0).toUpperCase()+state.category.slice(1);
  document.getElementById('qCounter').textContent=`Q ${num} / ${tot}`;
  document.getElementById('liveScore').textContent=state.score;
  document.getElementById('questionNum').textContent=`Question ${num}`;
  document.getElementById('questionText').textContent=q.q;

  /* Génération dynamique des options */
  const grid=document.getElementById('optionsGrid');
  grid.innerHTML='';
  const letters=['A','B','C','D'];
  q.opts.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.className='option-btn';
    btn.id='opt-'+i;
    btn.innerHTML=`<span class="opt-letter">${letters[i]}</span><span>${opt}</span>`;
    btn.addEventListener('click',()=>selectAnswer(i));
    grid.appendChild(btn);
  });

  /* Reset UI */
  const panel=document.getElementById('feedbackPanel');
  panel.classList.remove('show','feedback-correct','feedback-wrong','feedback-timeout');
  document.getElementById('hintPanel').classList.remove('show');
  document.getElementById('hintText').textContent='';
  document.getElementById('dcBadge').classList.remove('show');
  document.getElementById('nextBtn').disabled=true;
  document.getElementById('skipBtn').disabled=false;
  document.getElementById('pointsBadgeWrap').innerHTML='';
  state.dcActive=false;
  state.dcFirstWrong=false;

  /* Dots */
  document.querySelectorAll('.pdot').forEach((d,i)=>{
    d.classList.remove('current');
    if(i===state.current) d.classList.add('current');
  });

  /* Streak badge */
  updateStreakBadge();

  startTimer();
  state.questionStartTime=Date.now();
}

/* ════════════════════════════════════════════════════════════════
   TIMER
════════════════════════════════════════════════════════════════ */
function startTimer(){
  clearInterval(state.timerInterval);
  state.timeLeft=state.maxTime;
  updateTimerUI();
  state.timerInterval=setInterval(()=>{
    state.timeLeft--;
    updateTimerUI();
    if(state.timeLeft<=0){clearInterval(state.timerInterval);autoTimeout();}
  },1000);
}
function updateTimerUI(){
  const pct=(state.timeLeft/state.maxTime)*100;
  const bar=document.getElementById('timerBar');
  bar.style.width=pct+'%';
  bar.className='timer-bar'+(state.timeLeft<=5?' warning':'');
  document.getElementById('timerText').textContent=state.timeLeft+'s';
}
function autoTimeout(){
  const q=state.questions[state.current];
  document.querySelectorAll('.option-btn').forEach((btn,i)=>{btn.disabled=true;if(i===q.ans)btn.classList.add('correct');});
  recordAnswer(-1,false,0);
  showFeedback('timeout',q,-1,0);
  document.getElementById('nextBtn').disabled=false;
  document.getElementById('skipBtn').disabled=true;
  if(state.isSuddenDeath){triggerSuddenDeath('Temps écoulé !');}
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 2 : JOKERS (BOUÉES DE SAUVETAGE)
════════════════════════════════════════════════════════════════ */

/* ── Joker 50:50 ── */
function useLifeline5050(){
  if(!state.lifelines.fiftyfifty) return;
  state.lifelines.fiftyfifty=false;
  state.lifesUsed++;
  updateLifelineButtons();
  const q=state.questions[state.current];
  const wrongIdxs=[];
  for(let i=0;i<q.opts.length;i++){if(i!==q.ans)wrongIdxs.push(i);}
  const toElim=shuffle(wrongIdxs).slice(0,2);
  toElim.forEach(i=>{
    const btn=document.getElementById('opt-'+i);
    if(btn){btn.classList.add('eliminated');btn.disabled=true;}
  });
  showToast('🎯','Joker 50:50 utilisé !','Deux mauvaises réponses ont été éliminées.','ach-cyan');
}

/* ── Joker Indice ── */
function useLifelineHint(){
  if(!state.lifelines.hint) return;
  state.lifelines.hint=false;
  state.lifesUsed++;
  updateLifelineButtons();
  const q=state.questions[state.current];
  document.getElementById('hintText').textContent=q.hint||'Pas d\'indice disponible pour cette question.';
  document.getElementById('hintPanel').classList.add('show');
  showToast('💡','Indice révélé !','Analysez l\'indice avec attention.','ach-gold');
}

/* ── Joker Double Chance ── */
function useLifelineDC(){
  if(!state.lifelines.doublechance) return;
  state.lifelines.doublechance=false;
  state.lifesUsed++;
  state.dcActive=true;
  updateLifelineButtons();
  document.getElementById('dcBadge').classList.add('show');
  showToast('💗','Double Chance activée !','Vous avez le droit à une 2ème tentative.','ach-pink');
}

function updateLifelineButtons(){
  const b5050 =document.getElementById('ll5050');
  const bHint =document.getElementById('llHint');
  const bDC   =document.getElementById('llDC');
  b5050.disabled=!state.lifelines.fiftyfifty;
  bHint.disabled=!state.lifelines.hint;
  bDC.disabled  =!state.lifelines.doublechance;
  document.getElementById('dot5050').style.display=state.lifelines.fiftyfifty?'none':'block';
  document.getElementById('dotHint').style.display=state.lifelines.hint?'none':'block';
  document.getElementById('dotDC').style.display  =state.lifelines.doublechance?'none':'block';
  /* Masquer jokers en Sudden Death ? Non — ils restent disponibles. */
}

/* ════════════════════════════════════════════════════════════════
   SÉLECTION D'UNE RÉPONSE
════════════════════════════════════════════════════════════════ */
function selectAnswer(idx){
  const q=state.questions[state.current];
  const correct=(idx===q.ans);

  /* ── Double Chance : premier mauvais essai ── */
  if(!correct && state.dcActive && !state.dcFirstWrong){
    state.dcFirstWrong=true;
    const btn=document.getElementById('opt-'+idx);
    if(btn){btn.classList.add('wrong');btn.disabled=true;}
    showFeedback('wrong_dc',q,idx,0);
    document.getElementById('dcBadge').classList.remove('show');
    /* Ne pas terminer la question, laisser un autre choix */
    return;
  }

  /* ── Réponse finale ── */
  clearInterval(state.timerInterval);
  const elapsed=(Date.now()-state.questionStartTime)/1000;
  state.timeData.push(elapsed);

  document.querySelectorAll('.option-btn').forEach((btn,i)=>{
    btn.disabled=true;
    if(i===q.ans) btn.classList.add('correct');
    if(i===idx && !correct) btn.classList.add('wrong');
    if(i===idx && correct)  btn.classList.add('selected-correct');
    if(i===idx && !correct) btn.classList.add('selected-wrong');
  });

  state.dcActive=false;

  let pointsEarned=0;
  if(correct){
    /* ── Étape 3 Instruction 1 : calcul des points ── */
    pointsEarned=calculatePoints();
    state.score+=pointsEarned;
    state.streak++;
    if(state.streak>state.maxStreak) state.maxStreak=state.streak;

    /* Mise à jour score avec animation */
    document.getElementById('liveScore').textContent=state.score;
    const sd=document.getElementById('scoreDisplay');
    sd.classList.remove('bump');void sd.offsetWidth;sd.classList.add('bump');
  } else {
    state.streak=0;
  }

  updateStreakBadge();
  recordAnswer(idx,correct,pointsEarned);
  showFeedback(correct?'correct':'wrong',q,idx,pointsEarned);
  document.getElementById('nextBtn').disabled=false;
  document.getElementById('skipBtn').disabled=true;

  const dot=document.getElementById('dot-'+state.current);
  dot.classList.remove('current');
  dot.classList.add(correct?'correct':'wrong');

  /* ── Mode Sudden Death ── */
  if(!correct && state.isSuddenDeath){
    setTimeout(()=>triggerSuddenDeath('Vous avez répondu incorrectement.'),800);
  }
}

/* ════════════════════════════════════════════════════════════════
   CALCUL DES POINTS avec multiplicateur de série
════════════════════════════════════════════════════════════════ */
function calculatePoints(){
  const base=SCORING[state.difficulty].base;
  const timeBonus=Math.max(0,Math.floor((state.timeLeft/state.maxTime)*50));
  /* ── Étape 4 : multiplicateur de streak ── */
  let streakMult=1;
  if(state.streak>=7) streakMult=2;
  else if(state.streak>=3) streakMult=1.5;
  return Math.round((base+timeBonus)*streakMult);
}

/* ── Streak badge ── */
function updateStreakBadge(){
  const badge=document.getElementById('streakBadge');
  const multEl=document.getElementById('streakMult');
  if(state.streak>=3){
    const m=state.streak>=7?2:1.5;
    multEl.textContent=m;
    badge.classList.add('visible');
  } else {
    badge.classList.remove('visible');
  }
}

/* ════════════════════════════════════════════════════════════════
   ENREGISTREMENT & FEEDBACK
════════════════════════════════════════════════════════════════ */
function recordAnswer(idx,correct,points){
  state.answered.push({q:state.questions[state.current],selected:idx,correct,points});
}

function showFeedback(type,q,idx,points){
  const panel  =document.getElementById('feedbackPanel');
  const icon   =document.getElementById('feedbackIcon');
  const title  =document.getElementById('feedbackTitle');
  const explain=document.getElementById('feedbackExplain');
  const badge  =document.getElementById('pointsBadgeWrap');

  panel.classList.remove('feedback-correct','feedback-wrong','feedback-timeout');
  badge.innerHTML='';

  if(type==='correct'){
    panel.classList.add('feedback-correct');
    icon.textContent='✅';
    title.textContent='Bonne réponse !';
    title.className='feedback-title correct-text';
    let streakInfo='';
    if(state.streak>=7)      streakInfo=' — Multiplicateur ×2 actif 🔥🔥';
    else if(state.streak>=3) streakInfo=' — Multiplicateur ×1.5 actif 🔥';
    badge.innerHTML=`<div class="points-badge">+${points} pts${streakInfo}</div>`;
  } else if(type==='wrong_dc'){
    panel.classList.add('feedback-wrong');
    icon.textContent='💗';
    title.textContent='Incorrect ! Essayez encore (Double Chance active)…';
    title.className='feedback-title wrong-text';
    explain.textContent='';
    panel.classList.add('show');
    return;
  } else if(type==='wrong'){
    panel.classList.add('feedback-wrong');
    icon.textContent='❌';
    title.textContent=`Incorrect — Réponse : « ${q.opts[q.ans]} »`;
    title.className='feedback-title wrong-text';
  } else {
    panel.classList.add('feedback-timeout');
    icon.textContent='⏱️';
    title.textContent=`Temps écoulé — Réponse : « ${q.opts[q.ans]} »`;
    title.className='feedback-title timeout-text';
  }
  explain.textContent=q.exp;
  panel.classList.add('show');
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — MODE SUDDEN DEATH
════════════════════════════════════════════════════════════════ */
function triggerSuddenDeath(msg){
  if(state.sdTriggered) return;
  state.sdTriggered=true;
  clearInterval(state.timerInterval);
  /* Enregistrer la question courante si pas encore enregistrée */
  if(state.answered.length<=state.current){
    recordAnswer(state.questions[state.current]?.ans??-1,false,0);
  }
  document.getElementById('sdMsg').innerHTML=`${msg}<br><strong>Le quiz se termine ici.</strong><br><small>Vos résultats ont quand même été enregistrés.</small>`;
  document.getElementById('sdOverlay').classList.remove('hidden');
}

/* ════════════════════════════════════════════════════════════════
   PASSER / SUIVANT
════════════════════════════════════════════════════════════════ */
function skipQuestion(){
  clearInterval(state.timerInterval);
  state.skipped++;state.streak=0;
  const q=state.questions[state.current];
  document.querySelectorAll('.option-btn').forEach((btn,i)=>{btn.disabled=true;if(i===q.ans)btn.classList.add('correct');});
  recordAnswer(-2,false,0);
  const dot=document.getElementById('dot-'+state.current);
  dot.classList.remove('current');dot.classList.add('wrong');
  showFeedback('wrong',q,-2,0);
  document.getElementById('nextBtn').disabled=false;
  document.getElementById('skipBtn').disabled=true;
  updateStreakBadge();
}

function nextQuestion(){
  state.current++;
  if(state.current>=state.questions.length) showResults();
  else showQuestion();
}

/* ════════════════════════════════════════════════════════════════
   RÉSULTATS
════════════════════════════════════════════════════════════════ */
function showResults(){
  clearInterval(state.timerInterval);

  const nbCorrect=state.answered.filter(a=>a.correct).length;
  const total=state.answered.length||state.questions.length;
  const pct=Math.round((nbCorrect/total)*100);
  const avgTime=state.timeData.length>0?Math.round(state.timeData.reduce((a,b)=>a+b,0)/state.timeData.length):0;

  /* Enregistrement classement */
  const entry={
    name: `Partie ${leaderboard.length+1}`,
    score: state.score,
    pct,
    diff: SCORING[state.difficulty].label,
    mode: state.isSuddenDeath?'💀 SD':'🎮',
    streak: state.maxStreak,
    date: new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}),
  };
  leaderboard.push(entry);
  leaderboard.sort((a,b)=>b.score-a.score);

  showScreen('resultsScreen');

  /* Anneau */
  const ring=document.getElementById('scoreRing');
  const circum=2*Math.PI*75; // r=75
  const dashOffset=circum-(pct/100)*circum;
  const ringColor=pct>=80?'#10b981':pct>=50?'#f59e0b':'#ef4444';
  ring.style.strokeDasharray=circum;
  ring.style.stroke=ringColor;
  setTimeout(()=>{ring.style.strokeDashoffset=dashOffset;},100);

  /* % animé */
  let displayed=0;
  const interval=setInterval(()=>{
    displayed=Math.min(displayed+2,pct);
    document.getElementById('scorePct').textContent=displayed+'%';
    if(displayed>=pct) clearInterval(interval);
  },20);

  /* Titre */
  let rTitle,rSub;
  if(pct>=90)     {rTitle='🏆 Extraordinaire !';rSub=`Expert absolu ! Score : ${state.score} pts`}
  else if(pct>=75){rTitle='⭐ Excellent travail !';rSub=`Très belle performance ! Score : ${state.score} pts`}
  else if(pct>=60){rTitle='👍 Bien joué !';rSub=`Vous vous en êtes bien sorti ! Score : ${state.score} pts`}
  else if(pct>=40){rTitle='📚 Peut mieux faire';rSub=`Continuez à apprendre ! Score : ${state.score} pts`}
  else            {rTitle='💪 Courage !';rSub=`Réessayez, vous pouvez faire mieux ! Score : ${state.score} pts`}

  document.getElementById('resultTitle').textContent=rTitle;
  document.getElementById('resultSubtitle').textContent=rSub;
  document.getElementById('finalScoreValue').textContent=state.score;
  document.getElementById('diffLabel').textContent=SCORING[state.difficulty].label;
  document.getElementById('modeLabel').textContent=state.isSuddenDeath?'💀 Sudden Death':'🎮 Normal';
  document.getElementById('correctCount').textContent=nbCorrect;
  document.getElementById('wrongCount').textContent=total-nbCorrect;
  document.getElementById('timeUsed').textContent=avgTime+'s';

  /* Streak */
  if(state.maxStreak>=3){
    document.getElementById('streakBannerRes').style.display='flex';
    const mult=state.maxStreak>=7?'×2':'×1.5';
    document.getElementById('streakTextRes').textContent=`🎯 Meilleure série : ${state.maxStreak} bonnes réponses consécutives ! Multiplicateur ${mult} appliqué sur ces réponses.`;
  } else {
    document.getElementById('streakBannerRes').style.display='none';
  }

  /* ── Étape 4 : Achievements ── */
  const stats={pct,avgTime,maxStreak:state.maxStreak,lifesUsed:state.lifesUsed,mode:state.mode,answered:state.answered};
  buildAchievements(stats);

  /* ── Étape 4 : Graphique ── */
  buildChart();

  /* Révision */
  buildReviewList();

  /* Classement */
  buildLeaderboard();

  if(pct>=80) launchConfetti();
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 2 : ACHIEVEMENTS
════════════════════════════════════════════════════════════════ */
function buildAchievements(stats){
  const grid=document.getElementById('achievementsGrid');
  grid.innerHTML='';
  let anyUnlocked=false;
  let toastDelay=0;

  ACHIEVEMENTS.forEach((ach,i)=>{
    const unlocked=ach.test(stats);
    if(unlocked) anyUnlocked=true;
    const el=document.createElement('div');
    el.className=`ach-badge ${unlocked?'unlocked '+ach.color:'locked'}`;
    el.style.animationDelay=`${i*0.08}s`;
    el.title=unlocked?`✅ Débloqué — ${ach.desc}`:`🔒 Condition : ${ach.desc}`;
    el.innerHTML=`<span class="ach-icon">${ach.icon}</span><span>${ach.label}</span>`;
    grid.appendChild(el);
    if(unlocked){
      setTimeout(()=>showToast(ach.icon,`Badge débloqué : ${ach.label}`,ach.desc,'ach'),toastDelay*600);
      toastDelay++;
    }
  });

  if(!anyUnlocked){
    grid.innerHTML='<div style="color:var(--muted);font-size:13px;padding:8px">Aucun badge débloqué cette partie. Passez votre souris sur les badges verrouillés pour voir les conditions !</div>';
  }
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 2 : GRAPHIQUE DE PROGRESSION
════════════════════════════════════════════════════════════════ */
function buildChart(){
  const bars=document.getElementById('chartBars');
  bars.innerHTML='';
  const maxTime=Math.max(...state.timeData,1);

  state.answered.forEach((ans,i)=>{
    const wrap=document.createElement('div');
    wrap.className='chart-bar-wrap';
    const bar=document.createElement('div');
    const t=state.timeData[i]||0;
    const h=Math.max(8,Math.round((t/maxTime)*70));
    bar.className='chart-bar '+(ans.correct?'bar-correct':ans.selected===-2?'bar-skip':'bar-wrong');
    bar.style.height='4px';
    bar.title=`Q${i+1} — ${ans.correct?'✅':ans.selected===-2?'⏭️':'❌'} — ${t.toFixed(1)}s`;
    const label=document.createElement('div');
    label.className='chart-label';
    label.textContent=(i+1).toString();
    wrap.appendChild(bar);
    wrap.appendChild(label);
    bars.appendChild(wrap);
    setTimeout(()=>{bar.style.height=h+'px';},100+i*60);
  });
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 2 : CLASSEMENT
════════════════════════════════════════════════════════════════ */
function buildLeaderboard(){
  const list=document.getElementById('leaderboardList');
  list.innerHTML='';

  if(leaderboard.length===0){
    list.innerHTML='<div class="lb-empty">🏆 Aucune partie enregistrée pour l\'instant.<br>Terminez votre premier quiz pour apparaître ici !<br><small style="font-size:11px;opacity:.6">Le classement est conservé pendant toute la session.</small></div>';
    return;
  }

  const top10=leaderboard.slice(0,10);
  const currentIdx=top10.findIndex(e=>e===leaderboard[leaderboard.length-1]);

  top10.forEach((entry,rank)=>{
    const el=document.createElement('div');
    const isCurrent=(rank===currentIdx);
    el.className='lb-entry'+(isCurrent?' is-current':'');
    const rankIcons=['🥇','🥈','🥉'];
    const rankHtml=rank<3
      ?`<span class="lb-rank ${['gold','silver','bronze'][rank]}">${rankIcons[rank]}</span>`
      :`<span class="lb-rank">${rank+1}</span>`;
    el.innerHTML=`
      ${rankHtml}
      <div class="lb-info">
        <div class="lb-name">${entry.name}${isCurrent?' <span style="color:var(--accent);font-size:11px;font-weight:600"> ← vous</span>':''}</div>
        <div class="lb-meta">${entry.diff} · ${entry.mode} · Série max : ${entry.streak} 🔥 · ${entry.pct}% réussite · ${entry.date}</div>
      </div>
      <div class="lb-score">★ ${entry.score.toLocaleString('fr-FR')}</div>
    `;
    list.appendChild(el);
  });
}

/* ════════════════════════════════════════════════════════════════
   RÉVISION
════════════════════════════════════════════════════════════════ */
function buildReviewList(){
  const reviewList=document.getElementById('reviewList');
  reviewList.innerHTML='';
  const letters=['A','B','C','D'];
  state.answered.forEach((ans,i)=>{
    const item=document.createElement('div');
    item.className='review-item '+(ans.correct?'correct-item':'wrong-item');
    let statusHtml;
    if(ans.correct) statusHtml=`<span class="review-status ok">✅ Correct +${ans.points} pts</span>`;
    else if(ans.selected===-2) statusHtml=`<span class="review-status sk">⏭️ Passée</span>`;
    else statusHtml=`<span class="review-status ko">❌ Incorrect 0 pt</span>`;
    const answersHtml=ans.q.opts.map((opt,j)=>{
      let cls='neutral-ans',icon='○';
      if(j===ans.q.ans){cls='correct-ans';icon='✓';}
      if(j===ans.selected&&j!==ans.q.ans){cls='wrong-ans';icon='✗';}
      return `<div class="review-ans ${cls}"><span class="review-num">${letters[j]}</span>${icon} ${opt}</div>`;
    }).join('');
    item.innerHTML=`${statusHtml}<div class="review-q">${i+1}. ${ans.q.q}</div><div class="review-answers">${answersHtml}</div><div class="review-exp"><strong>💡 Explication :</strong> ${ans.q.exp}</div>`;
    reviewList.appendChild(item);
  });
}

/* ════════════════════════════════════════════════════════════════
   ONGLETS
════════════════════════════════════════════════════════════════ */
function showTab(name){
  ['stats','chart','review','lb'].forEach(t=>{
    document.getElementById('tab'+t.charAt(0).toUpperCase()+t.slice(1)).classList.toggle('active',t===name);
    document.getElementById(t+'Tab').classList.toggle('active',t===name);
  });
}

/* ════════════════════════════════════════════════════════════════
   ÉTAPE 4 — INSTRUCTION 2 : TOAST DE NOTIFICATION
════════════════════════════════════════════════════════════════ */
let toastQueue=[];
function showToast(icon,title,sub,colorClass){
  /* Limiter à 3 toasts simultanés */
  const container=document.getElementById('toastContainer');
  if(container.children.length>=3) return;

  const toast=document.createElement('div');
  toast.className='toast';
  toast.innerHTML=`<div class="toast-icon">${icon}</div><div class="toast-body"><div class="toast-title">${title}</div><div class="toast-sub">${sub}</div></div>`;
  container.appendChild(toast);

  setTimeout(()=>{
    toast.classList.add('toast-out');
    setTimeout(()=>toast.remove(),400);
  },3000);
}

/* ════════════════════════════════════════════════════════════════
   REJOUER / ACCUEIL
════════════════════════════════════════════════════════════════ */
function retryQuiz(){startQuiz();}
function goHome(){
  clearInterval(state.timerInterval);
  document.getElementById('sdOverlay').classList.add('hidden');
  showScreen('homeScreen');
  document.getElementById('confettiContainer').innerHTML='';
  document.getElementById('streakBannerRes').style.display='none';
}

/* ════════════════════════════════════════════════════════════════
   CONFETTIS
════════════════════════════════════════════════════════════════ */
function launchConfetti(){
  const colors=['#7c3aed','#06b6d4','#f59e0b','#10b981','#ef4444','#ec4899'];
  const container=document.getElementById('confettiContainer');
  container.innerHTML='';
  for(let i=0;i<80;i++){
    const p=document.createElement('div');
    p.className='confetti-piece';
    const c=colors[Math.floor(Math.random()*colors.length)];
    const l=Math.random()*100, dur=1.5+Math.random()*2, del=Math.random()*1.5, sz=6+Math.random()*10;
    p.style.cssText=`left:${l}%;background:${c};width:${sz}px;height:${sz}px;animation-duration:${dur}s;animation-delay:${del}s;border-radius:${Math.random()>.5?'50%':'2px'};`;
    container.appendChild(p);
    setTimeout(()=>p.remove(),(dur+del)*1000+500);
  }
}
</script>
