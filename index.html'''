<script>
/* ════════════════════════════════════════════════════════════════
   BANQUE DE QUESTIONS (6 catégories × 3 niveaux × 10 questions)
   Chaque question possède un champ `hint` pour le joker "Indice"
════════════════════════════════════════════════════════════════ */
const QUESTIONS = {
  science:{
    facile:[
      {q:"Quelle planète est la plus proche du Soleil ?",opts:["Mercure","Vénus","Mars","Jupiter"],ans:0,exp:"Mercure est la planète la plus proche du Soleil avec une orbite d'environ 58 millions de km.",hint:"Elle est aussi la plus petite planète du système solaire."},
